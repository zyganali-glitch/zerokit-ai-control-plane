{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zerokit.example/schemas/zerokit.config.schema.json",
  "title": "ZeroKit Public Judging Edition Config",
  "type": "object",
  "required": ["panel_registry", "rbac_registry", "field_registry", "endpoint_map"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "panel_registry": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/panelRegistryEntry" }
    },
    "rbac_registry": { "$ref": "#/$defs/rbacRegistry" },
    "field_registry": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    },
    "endpoint_map": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "brand_config": { "type": "object" },
    "privacy_notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "test_checklist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "localizedName": {
      "type": "object",
      "properties": {
        "tr": { "type": "string", "minLength": 1 },
        "en": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "panelRegistryEntry": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "visible": { "type": "boolean" },
        "order": { "type": "number" },
        "group": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "rbacRole": {
      "type": "object",
      "required": ["slug", "permissions"],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "level": { "type": "number" },
        "name": { "$ref": "#/$defs/localizedName" },
        "permissions": {
          "oneOf": [
            { "const": "*" },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          ]
        }
      },
      "additionalProperties": true
    },
    "rbacRegistry": {
      "type": "object",
      "required": ["roles"],
      "properties": {
        "permissions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/rbacRole" }
        },
        "hierarchy_tree": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}

